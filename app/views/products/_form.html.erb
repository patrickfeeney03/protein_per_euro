<%= form_with(model: product, class: "contents space-y-4") do |f| %>
  <% if product.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(product.errors.count, "error") %> prohibited this product from being saved:</h2>

      <ul class="list-disc ml-6">
        <% product.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="flex items-center justify-between">
    <%= f.label :name %>
    <%= f.text_field :name, class: "w-1/2" %>
  </div>

  <div class="flex items-center justify-between">
    <%= f.label :date_bought %>
    <div class="w-1/2 flex flex-col">
      <%= f.date_select :date_bought, { }, { class: "w-full" } %>
    </div>
  </div>

  <div class="flex items-center justify-between">
    <%= f.label :place_bought %>
    <%= f.text_field :place_bought, class: "w-1/2" %>
  </div>

  <div class="flex items-center justify-between">
    <%= f.label :calories %>
    <%= f.number_field :calories, step: 0.01, class: "w-1/2" %>
  </div>

  <div class="flex items-center justify-between">
    <%= f.label :protein %>
    <%= f.number_field :protein, step: 0.01, class: "w-1/2" %>
  </div>

  <div class="flex items-center justify-between">
    <%= f.label :carbohydrates %>
    <%= f.number_field :carbohydrates, step: 0.01, class: "w-1/2" %>
  </div>

  <div class="flex items-center justify-between">
    <%= f.label :fats %>
    <%= f.number_field :fats, step: 0.01, class: "w-1/2" %>
  </div>

  <div class="flex items-center justify-between">
    <%= f.label :total_weight %>
    <%= f.number_field :total_weight, step: 0.01, class: "w-1/2" %>
  </div>

  <div class="flex items-center justify-between">
    <%= f.label :weight_for_macros %>
    <%= f.number_field :weight_for_macros, step: 0.01, class: "w-1/2" %>
  </div>

  <div class="flex items-center justify-between">
    <%= f.label :price %>
    <%= f.number_field :price, step: 0.01, class: "w-1/2" %>
  </div>

  <div class="inline">
    <%= f.submit class: "mt-6 rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
