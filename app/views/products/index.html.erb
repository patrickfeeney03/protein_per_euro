<% content_for :title, "Products" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center ">
    <h1 class="font-bold text-4xl my-0">Home</h1>
    <%= link_to "New product", new_product_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block text-base" if authenticated? %>
  </div>

  <h2 class="mt-3 mb-2">Your Saved Products</h2>
  <span>Touch any product to view more details</span>
  <%= render "table", products: @products %>
  <%= "There are no products in your account" unless @products.any? %>

  <h2 class="mt-2 mb-2">Products from other people</h2>
  <%= render "table", products: @other_products %>
  <%= "There are no products in other accounts" unless @other_products.any? %>
</div>
