<div id="<%= dom_id product %>">
</div>

<div>
  <span class="font-bold">Name:</span> <%= product.name %>
</div>

<div>Date bought: <%= product.date_bought.strftime("%v") if product.date_bought? %></div>

<div>Place bought: <%= product.place_bought %></div>

<div class="mt-3 mb-3 bold">
  <span class="font-bold">Protein Per Euro:</span> <%= product.protein_per_euro %>
</div>

<div>Total weight: <%= format_number_table(product.total_weight) if product.total_weight? %> grams</div>
<div>Price: <%= format_number_table(product.price) unless product.price.nil? %>€</div>

<% if product.weight_for_macros != 100 %>
  <div class="mt-3 mb-3">
    <span class="font-bold">Values per 100 grams:</span>
    <%= render "product_macros", product: product, multiply_to_100: true %>
  </div>
  <div class="mt-3 mb-3">
    <span class="font-bold">Values per <%= format_number_table(product.weight_for_macros) if product.weight_for_macros %> grams serving:</span>
    <%= render "product_macros", product: product, multiply_to_100: false %>
  </div>
<% else %>
  <div class="mt-3 mb-3">
    <span class="font-bold">Values per 100 grams:</span>
    <%= render "product_macros", product: product, multiply_to_100: false %>
  </div>
<% end %>

<div>Weight used for calculations: <%= format_number_table(product.weight_for_macros) if product.weight_for_macros %> grams</div>
<% if product.image.present? %>
  <details class="mt-4 mb-4">
    <summary class="cursor-pointer font-bold text-base bg-gray-200 hover:bg-gray-100 p-2 rounded-md ">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-5 inline align-text-bottom">
        <path fill-rule="evenodd" d="M1 5.25A2.25 2.25 0 0 1 3.25 3h13.5A2.25 2.25 0 0 1 19 5.25v9.5A2.25 2.25 0 0 1 16.75 17H3.25A2.25 2.25 0 0 1 1 14.75v-9.5Zm1.5 5.81v3.69c0 .414.336.75.75.75h13.5a.75.75 0 0 0 .75-.75v-2.69l-2.22-2.219a.75.75 0 0 0-1.06 0l-1.91 1.909.47.47a.75.75 0 1 1-1.06 1.06L6.53 8.091a.75.75 0 0 0-1.06 0l-2.97 2.97ZM12 7a1 1 0 1 1-2 0 1 1 0 0 1 2 0Z" clip-rule="evenodd" />
      </svg>
      Additional Information Image
    </summary>
    <div>
      <%= image_tag product.image, class: "mt-2" %>
    </div>
  </details>
<% end %>
